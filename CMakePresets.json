{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "msvc-x86-debug",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/stage1-msvc-x86-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "cl"
      }
    },
    {
      "name": "msvc-x64-release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/stage1-msvc-x64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "cl"
      }
    },
    {
      "name": "clang-cl-x64-debug",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/stage1-clang-cl-x64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang-cl"
      }
    },
    {
      "name": "clang-cl-x64-asan",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/stage2-clang-cl-x64-asan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "clang-cl",
        "VPS_ENABLE_ASAN": "ON",
        "VPS_BUILD_FUZZ": "ON"
      }
    },
    {
      "name": "clang-cl-x64-ubsan",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/stage15-clang-cl-x64-ubsan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "clang-cl",
        "VPS_ENABLE_UBSAN": "ON",
        "VPS_BUILD_FUZZ": "ON"
      }
    },
    {
      "name": "msvc-x86-static-analysis",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/stage15-msvc-x86-static-analysis",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "cl",
        "VPS_ENABLE_MSVC_ANALYZE": "ON"
      }
    },
    {
      "name": "msvc-x64-static-analysis",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/stage15-msvc-x64-static-analysis",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "cl",
        "VPS_ENABLE_MSVC_ANALYZE": "ON"
      }
    },
    {
      "name": "clang-tidy-x64-static-analysis",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/stage15-clang-tidy-x64-static-analysis",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang-cl",
        "VPS_ENABLE_CLANG_TIDY": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "msvc-x86-debug", "configurePreset": "msvc-x86-debug" },
    { "name": "msvc-x64-release", "configurePreset": "msvc-x64-release" },
    { "name": "clang-cl-x64-debug", "configurePreset": "clang-cl-x64-debug" },
    { "name": "clang-cl-x64-asan", "configurePreset": "clang-cl-x64-asan" },
    { "name": "clang-cl-x64-ubsan", "configurePreset": "clang-cl-x64-ubsan" },
    { "name": "msvc-x86-static-analysis", "configurePreset": "msvc-x86-static-analysis" },
    { "name": "msvc-x64-static-analysis", "configurePreset": "msvc-x64-static-analysis" },
    { "name": "clang-tidy-x64-static-analysis", "configurePreset": "clang-tidy-x64-static-analysis" }
  ],
  "testPresets": [
    {
      "name": "msvc-x86-debug",
      "configurePreset": "msvc-x86-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "msvc-x64-release",
      "configurePreset": "msvc-x64-release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "clang-cl-x64-debug",
      "configurePreset": "clang-cl-x64-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "clang-cl-x64-asan",
      "configurePreset": "clang-cl-x64-asan",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "clang-cl-x64-ubsan",
      "configurePreset": "clang-cl-x64-ubsan",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "msvc-x86-static-analysis",
      "configurePreset": "msvc-x86-static-analysis",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "msvc-x64-static-analysis",
      "configurePreset": "msvc-x64-static-analysis",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "clang-tidy-x64-static-analysis",
      "configurePreset": "clang-tidy-x64-static-analysis",
      "output": { "outputOnFailure": true }
    }
  ]
}
